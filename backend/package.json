    "@fastify/websocket": "^11.2.0",
    "@google-cloud/storage": "^7.14.0",
    "@google-cloud/vertexai": "^1.9.0",
    "@google/generative-ai": "^0.21.0",
    "@prisma/client": "^6.2.0",
    "bull": "^4.16.0",
    "fastify": "^5.2.0",
    "firebase-admin": "^13.0.0",
    "ioredis": "^5.4.0",
    "pg": "^8.20.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "pino-pretty": "^13.0.0",
