// STANNEL Database Schema - Prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  ARCHITECT
  SUPPLIER
}

enum UserRank {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum InvoiceStatus {
  PENDING_ADMIN
  CLARIFICATION_NEEDED
  APPROVED
  REJECTED
  PENDING_SUPPLIER_PAY
  PAID
  OVERDUE
}

enum ContractType {
  STANDARD
  PREMIUM
  EXCLUSIVE
}

model User {
  id              String          @id @default(cuid())
  firebaseUid     String          @unique
  email           String          @unique
  name            String
  phone           String?
  company         String?
  address         String?
  role            UserRole
  rank            UserRank        @default(BRONZE)
  isActive        Boolean         @default(false)
  activatedAt     DateTime?
  profileImage    String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  architectProfile  ArchitectProfile?
  supplierProfile   SupplierProfile?
  auditLogs         AuditLog[]
  eventRegistrations EventRegistration[]

  // New relations from BASE44 migration
  notifications     Notification[]
  profilesViewed    ProfileView[]  @relation("ProfileViewer")
  profileViewers    ProfileView[]  @relation("ProfileViewed")

  @@index([role, isActive])
  @@index([createdAt])
}

model ArchitectProfile {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  pointsBalance   Float     @default(0)
  cashBalance     Float     @default(0)
  totalEarned     Float     @default(0)
  totalRedeemed   Float     @default(0)

  cardNumber      String    @unique @default(cuid())
  cardExpiry      DateTime?

  monthlyGoal     Float     @default(0)
  monthlyProgress Float     @default(0)

  // Trust level for spending limits (Bronze: 5K, Silver: 15K, Gold: 50K)
  trustLevel      UserRank  @default(BRONZE)
  monthlyLimit    Float     @default(5000)
  monthlySpent    Float     @default(0)

  // Onboarding status
  onboardingStatus String   @default("pending_review") // limited, pending_review, approved, rejected
  businessId      String?

  invoices        Invoice[]
  cardTransactions CardTransaction[]
  goalBonuses     GoalBonus[]
  redemptions     Redemption[]

  // New relations from BASE44 migration
  architectGoals  ArchitectGoal[]
  bonusTransactions BonusTransaction[]
}

model SupplierProfile {
  id            String        @id @default(cuid())
  userId        String        @unique
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName   String
  trustScore    Float         @default(5.0)
  qualityScore  Float         @default(5.0)

  // Points system - same as architect
  pointsBalance   Float       @default(0)
  totalEarned     Float       @default(0)
  totalRedeemed   Float       @default(0)
  cardNumber      String?     @unique

  // Onboarding status
  onboardingStatus String     @default("pending_review") // pending_review, approved, rejected
  status          String      @default("active") // active, suspended, inactive

  // Public profile info
  description     String?
  phone           String?
  address         String?
  website         String?
  facebook        String?
  instagram       String?
  linkedin        String?
  businessImages  String[]    @default([])

  contracts     Contract[]
  invoices      Invoice[]
  supplierGoals SupplierGoal[]
  products      Product[]
  cardTransactions SupplierCardTransaction[]

  // New relations from BASE44 migration
  supplierPayments SupplierPayment[]
  projects        SupplierProject[]
}

model Invoice {
  id              String          @id @default(cuid())
  imageUrl        String
  amount          Float
  status          InvoiceStatus   @default(PENDING_ADMIN)

  architectId     String
  architect       ArchitectProfile @relation(fields: [architectId], references: [id])
  supplierId      String
  supplier        SupplierProfile  @relation(fields: [supplierId], references: [id])

  slaDeadline     DateTime
  slaAlertSent    Boolean         @default(false)

  adminNote       String?
  supplierRef     String?
  paymentProofUrl String?         // URL of payment proof document uploaded by supplier

  createdAt       DateTime        @default(now())
  approvedAt      DateTime?
  paidAt          DateTime?
  deletedAt       DateTime?       // Soft delete - moves to recycle bin

  aiExtractedAmount Float?
  aiConfidence      Float?
  aiStatus          String?

  // Commission tracking (4% total: 2% architect points + 2% admin)
  adminCommission     Float?          // 2% admin commission in ₪
  architectPoints     Float?          // Points credited to architect (2% × 40)
  architectCommission Float?          // 2% architect commission in ₪ (before points conversion)

  statusHistory     InvoiceStatusHistory[]

  @@index([deletedAt])
  @@index([architectId])
  @@index([supplierId])
  @@index([status])
  @@index([createdAt])
  @@index([architectId, status])
  @@index([supplierId, status])
}

model InvoiceStatusHistory {
  id          String        @id @default(cuid())
  invoiceId   String
  invoice     Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  status      InvoiceStatus
  note        String?
  changedBy   String
  createdAt   DateTime      @default(now())

  @@index([invoiceId])
  @@index([createdAt])
}

model Contract {
  id          String        @id @default(cuid())
  supplierId  String
  supplier    SupplierProfile @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  type        ContractType
  feePercent  Float
  validFrom   DateTime
  validTo     DateTime
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())

  @@index([supplierId])
  @@index([isActive])
}

model Product {
  id              String    @id @default(cuid())
  name            String
  description     String?
  imageUrl        String
  pointCost       Float                   // Total points required for the product
  pointsPerShekel Float     @default(100) // Exchange rate: how many points = 1 shekel (for cash completion)
  stock           Int       @default(0)
  isActive        Boolean   @default(true)
  supplierId      String?
  supplier        SupplierProfile? @relation(fields: [supplierId], references: [id])
  createdAt       DateTime  @default(now())

  redemptions   Redemption[]

  @@index([isActive])
  @@index([supplierId])
}

model Redemption {
  id              String    @id @default(cuid())
  productId       String
  product         Product   @relation(fields: [productId], references: [id])
  architectId     String
  architect       ArchitectProfile @relation(fields: [architectId], references: [id])
  pointsUsed      Float
  cashPaid        Float     @default(0)
  createdAt       DateTime  @default(now())

  @@index([architectId])
  @@index([productId])
  @@index([architectId, createdAt])
  @@index([createdAt])
}

model CardTransaction {
  id            String    @id @default(cuid())
  architectId   String
  architect     ArchitectProfile @relation(fields: [architectId], references: [id], onDelete: Cascade)
  type          String
  amount        Float
  description   String
  invoiceId     String?
  createdAt     DateTime  @default(now())

  @@index([architectId])
  @@index([createdAt])
}

model SupplierCardTransaction {
  id            String    @id @default(cuid())
  supplierId    String
  supplier      SupplierProfile @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  type          String
  amount        Float
  description   String
  invoiceId     String?
  createdAt     DateTime  @default(now())

  @@index([supplierId])
  @@index([createdAt])
}

model Event {
  id              String    @id @default(cuid())
  title           String
  description     String
  imageUrl        String?
  date            DateTime
  location        String
  capacity        Int
  pointsCost      Int       @default(0)
  isHidden        Boolean   @default(false)
  registeredCount Int       @default(0)
  waitlistEnabled Boolean   @default(true)
  createdAt       DateTime  @default(now())

  registrations   EventRegistration[]

  @@index([date])
  @@index([isHidden])
}

model EventRegistration {
  id        String    @id @default(cuid())
  eventId   String
  event     Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    String    @default("CONFIRMED")
  createdAt DateTime  @default(now())

  @@unique([eventId, userId])
  @@index([userId])
  @@index([eventId])
}

model SupplierGoal {
  id            String    @id @default(cuid())
  supplierId    String
  supplier      SupplierProfile @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  targetAmount  Float
  bonusPoints   Float
  period        String
  startDate     DateTime
  endDate       DateTime
  isActive      Boolean   @default(true)

  @@index([supplierId])
  @@index([isActive])
}

model GoalBonus {
  id            String    @id @default(cuid())
  architectId   String
  architect     ArchitectProfile @relation(fields: [architectId], references: [id], onDelete: Cascade)
  goalId        String
  bonusPoints   Float
  awardedAt     DateTime  @default(now())

  @@index([architectId])
}

model AuditLog {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

enum SystemLogSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

enum SystemLogCategory {
  HEALTH_CHECK
  SECURITY
  API_TEST
  DATABASE
  PERFORMANCE
  SCHEDULER
  AUTH
  INVOICE
  REWARDS
  WALLET
  EVENTS
  ADMIN
  SUPPLIER
  USER
  EMAIL
  STORAGE
  AI
  FINANCIAL
}

model SystemLog {
  id          String              @id @default(cuid())
  severity    SystemLogSeverity
  category    SystemLogCategory
  title       String
  message     String
  details     String?             @db.Text // Full error details for copy/paste to Claude
  endpoint    String?
  method      String?             // HTTP method (GET, POST, etc.)
  userId      String?             // User who triggered the action
  userEmail   String?
  requestBody String?             @db.Text // Request payload (sanitized)
  responseTime Int?               // Response time in ms
  statusCode  Int?                // HTTP status code
  stackTrace  String?             @db.Text
  userAgent   String?
  ipAddress   String?
  resolved    Boolean             @default(false)
  resolvedAt  DateTime?
  resolvedBy  String?
  alertSent   Boolean             @default(false) // Was email alert sent?
  createdAt   DateTime            @default(now())

  @@index([createdAt])
  @@index([severity])
  @@index([resolved])
  @@index([category])
  @@index([userId])
}

model SystemScanReport {
  id              String    @id @default(cuid())
  isHealthy       Boolean
  checksRun       Int
  checksPassed    Int
  checksFailed    Int
  checksWarnings  Int
  results         Json      // Array of check results
  errorsLast24h   Int       @default(0)
  claudeFormat    String?   // Pre-formatted text for Claude
  emailSent       Boolean   @default(false)
  sentTo          String[]
  createdAt       DateTime  @default(now())

  @@index([createdAt])
}

// ============================================
// NEW MODELS - Migrated from BASE44
// ============================================

enum NotificationType {
  INVOICE_SUBMITTED
  INVOICE_APPROVED
  INVOICE_REJECTED
  INVOICE_CLARIFICATION
  INVOICE_PAID
  CARD_CREDITED
  GOAL_ACHIEVED
  BONUS_RECEIVED
  PROFILE_VIEWED
  SYSTEM_ALERT
  WELCOME
}

model Notification {
  id              String           @id @default(cuid())
  recipientId     String
  recipient       User             @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  type            NotificationType
  title           String
  message         String

  relatedEntity   String?          // e.g., "invoice", "goal", "user"
  relatedId       String?          // ID of the related entity

  isRead          Boolean          @default(false)
  readAt          DateTime?

  createdAt       DateTime         @default(now())

  @@index([recipientId, isRead])
  @@index([createdAt])
}

model ProfileView {
  id              String    @id @default(cuid())
  viewedUserId    String
  viewedUser      User      @relation("ProfileViewed", fields: [viewedUserId], references: [id], onDelete: Cascade)

  viewerId        String
  viewer          User      @relation("ProfileViewer", fields: [viewerId], references: [id], onDelete: Cascade)

  viewerName      String
  viewerRole      String

  createdAt       DateTime  @default(now())

  @@index([viewedUserId])
}

enum ServiceProviderCategory {
  CONTRACTOR
  ELECTRICIAN
  PLUMBER
  PAINTER
  CARPENTER
  LANDSCAPER
  INTERIOR_DESIGNER
  OTHER
}

model ServiceProvider {
  id              String                   @id @default(cuid())
  name            String
  phone           String?
  email           String?
  category        ServiceProviderCategory
  description     String?
  website         String?
  address         String?

  isActive        Boolean   @default(true)
  isVerified      Boolean   @default(false)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([category])
  @@index([isActive])
}

enum SupplierPaymentStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

model SupplierPayment {
  id              String                 @id @default(cuid())
  supplierId      String
  supplier        SupplierProfile        @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  invoiceId       String
  architectEmail  String
  amount          Float

  status          SupplierPaymentStatus  @default(PENDING)

  dueDate         DateTime
  paidAt          DateTime?
  paymentRef      String?

  createdAt       DateTime               @default(now())

  @@index([supplierId, status])
  @@index([dueDate])
}

enum GoalPeriodType {
  MONTHLY
  QUARTERLY
  YEARLY
}

model ArchitectGoal {
  id                    String          @id @default(cuid())
  architectId           String
  architect             ArchitectProfile @relation(fields: [architectId], references: [id], onDelete: Cascade)

  targetAmount          Float
  currentPeriodRevenue  Float           @default(0)
  bonusPercentage       Float           @default(5)

  periodType            GoalPeriodType  @default(MONTHLY)
  startDate             DateTime
  endDate               DateTime

  isActive              Boolean         @default(true)
  targetMet             Boolean         @default(false)
  targetMetAt           DateTime?

  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  bonusTransactions     BonusTransaction[]

  @@index([architectId, isActive])
}

enum BonusStatus {
  PENDING
  CREDITED
  FAILED
}

model BonusTransaction {
  id              String        @id @default(cuid())
  architectId     String
  architect       ArchitectProfile @relation(fields: [architectId], references: [id], onDelete: Cascade)

  goalId          String
  goal            ArchitectGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  bonusType       String        // e.g., "goal_achieved", "special_bonus"
  amount          Float

  status          BonusStatus   @default(PENDING)
  creditedAt      DateTime?

  createdAt       DateTime      @default(now())

  @@index([architectId])
}

// ============================================
// Supplier Projects - Portfolio showcase
// ============================================

model SupplierProject {
  id              String          @id @default(cuid())
  supplierId      String
  supplier        SupplierProfile @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  title           String
  description     String          @db.Text
  location        String?
  year            Int?
  area            String?         // e.g., "350 מ"ר"
  duration        String?         // e.g., "8 חודשים"

  // Images - first image is the cover
  images          String[]        @default([])

  isActive        Boolean         @default(true)
  order           Int             @default(0) // For ordering projects

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([supplierId, isActive])
  @@index([createdAt])
}
