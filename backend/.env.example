# STANNEL Backend Environment Variables

# Server
PORT=7070
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/stannel?schema=public"

# Redis (for SLA queues)
REDIS_URL="redis://localhost:6379"

# Google Cloud
GOOGLE_CLOUD_PROJECT=your-project-id
GCS_INVOICE_BUCKET=stannel-invoices
GCS_ASSETS_BUCKET=stannel-assets
VERTEX_LOCATION=us-central1

# Firebase Admin
FIREBASE_PROJECT_ID=your-firebase-project
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# JWT (if using custom tokens)
JWT_SECRET=your-super-secret-jwt-key

# Email (SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key
EMAIL_FROM=noreply@stannel.app
EMAIL_FROM_NAME=STANNEL Platform
